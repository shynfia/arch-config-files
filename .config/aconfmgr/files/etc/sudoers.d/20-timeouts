# Disable password prompt timeout. This prevents processes that elevate
# only as needed from dying due to a sudo prompt timeout.
# See https://wiki.archlinux.org/title/Sudo#Disable_password_prompt_timeout
Defaults passwd_timeout=0

# Increase default sudo timeout (default: 5min)
# Use sudo -K to revoke sudo if needed
# Use sudo -v in a loop to refresh timeout if needed
Defaults timestamp_timeout=999
